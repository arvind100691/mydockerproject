{
  "name": "mydockerproject-devcontainer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspaces/mydockerproject",
  "postCreateCommand": "cmake --version || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-vscode.cpptools-extension-pack"
      ],
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash",
        "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
        "clangd.arguments": [
          "--background-index"
        ]
      }
    }
  },
  "remoteUser": "root"
}
